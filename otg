can_render_fx() {
    [[ -t 1 ]] || return 1
    [[ "${TERM:-}" != "dumb" ]] || return 1
}

find_linux_sound() {
    local name path
    for name in "$@"; do
        for path in \
            "/usr/share/sounds/freedesktop/stereo/$name" \
            "/usr/share/sounds/gnome/default/alerts/$name" \
            "/usr/share/sounds/ubuntu/stereo/$name"
        do
            [[ -f "$path" ]] && {
                printf '%s' "$path"
                return 0
            }
        done
    done

    return 1
}

decode_base64_to_file() {
    local payload="$1" out_file="$2" tmp_file
    tmp_file="${out_file}.tmp"

    if printf '%s' "$payload" | base64 -d > "$tmp_file" 2>/dev/null || \
       printf '%s' "$payload" | base64 --decode > "$tmp_file" 2>/dev/null || \
       printf '%s' "$payload" | base64 -D > "$tmp_file" 2>/dev/null; then
        mv "$tmp_file" "$out_file"
        return 0
    fi

    rm -f "$tmp_file"
    return 1
}

bundled_sound_path() {
    local cue="$1" path payload
    ensure_init

    case "$cue" in
        boot)
            path="$OTG_CACHE_DIR/blocked_boot_${OTG_AUDIO_CACHE_TAG}.wav"
            payload="$OTG_BUNDLED_BOOT_WAV_B64"
            ;;
        deny)
            path="$OTG_CACHE_DIR/blocked_deny_${OTG_AUDIO_CACHE_TAG}.wav"
            payload="$OTG_BUNDLED_DENY_WAV_B64"
            ;;
        *)
            return 1
            ;;
    esac

    if [[ ! -s "$path" ]]; then
        decode_base64_to_file "$payload" "$path" || return 1
    fi

    printf '%s' "$path"
}

play_blocked_sound() {
    local cue="$1" sound="" event="" linux_sound="" bundled=""

    [[ "${OTG_SOUND:-1}" != "0" ]] || return 0
    [[ -t 1 ]] || return 0

    bundled="$(bundled_sound_path "$cue" 2>/dev/null || true)"

    if [[ -n "$bundled" ]]; then
        if command -v afplay >/dev/null 2>&1; then
            (afplay "$bundled" >/dev/null 2>&1 &) || true
            return 0
        fi

        if command -v paplay >/dev/null 2>&1; then
            (paplay "$bundled" >/dev/null 2>&1 &) || true
            return 0
        fi

        if command -v aplay >/dev/null 2>&1; then
            (aplay -q "$bundled" >/dev/null 2>&1 &) || true
            return 0
        fi
    fi

    if command -v canberra-gtk-play >/dev/null 2>&1; then
        case "$cue" in
            boot) event="message-new-instant" ;;
            deny) event="dialog-error" ;;
        esac

        (canberra-gtk-play -i "$event" >/dev/null 2>&1 &) || true
        return 0
    fi

    case "$cue" in
        boot)
            linux_sound="$(find_linux_sound \
                "message-new-instant.oga" \
                "complete.oga" \
                "dialog-information.oga" \
                "dialog-information.wav" 2>/dev/null || true)"
            ;;
        deny)
            linux_sound="$(find_linux_sound \
                "dialog-warning.oga" \
                "dialog-error.oga" \
                "dialog-error.wav" \
                "suspend-error.oga" 2>/dev/null || true)"
            ;;
    esac

    if [[ -n "$linux_sound" ]]; then
        if command -v paplay >/dev/null 2>&1; then
            (paplay "$linux_sound" >/dev/null 2>&1 &) || true
            return 0
        fi

        if command -v aplay >/dev/null 2>&1 && [[ "$linux_sound" == *.wav ]]; then
            (aplay -q "$linux_sound" >/dev/null 2>&1 &) || true
            return 0
        fi
    fi

    printf '\a'
    if [[ "$cue" == "deny" ]]; then
        sleep 0.05
        printf '\a'
    fi
}

# ─── Blocked Screen Animation ────────────────────

render_backdrop() {
    local cols="$1" lines="$2"
    local grid title subtitle clock title_col subtitle_col clock_col row

    grid="$(repeat_char "┈" "$((cols - 6))")"
    title="OTG / SYNAPTIC FIREWALL"
    subtitle="focus perimeter active"
    clock="LOCAL $(date +%H:%M:%S)"
    title_col=$(((cols - ${#title}) / 2 + 1))
    subtitle_col=$(((cols - ${#subtitle}) / 2 + 1))
    clock_col=$((cols - ${#clock} - 1))

    (( title_col < 1 )) && title_col=1
    (( subtitle_col < 1 )) && subtitle_col=1
    (( clock_col < 1 )) && clock_col=1

    clear_screen
    cursor_to 1 "$title_col"
    printf "%b%s%b" "$CY2" "$title" "$N"
    cursor_to 2 "$subtitle_col"
    printf "%b%s%b" "$SL" "$subtitle" "$N"
    cursor_to 2 "$clock_col"
    printf "%b%s%b" "$IG" "$clock" "$N"

    for ((row = 4; row <= lines - 2; row += 4)); do
        cursor_to "$row" 4
        printf "%b%s%b" "$DM" "$grid" "$N"
    done
}

build_meter() {
    local width="$1" head="$2" out="" i distance
    for ((i = 0; i < width; i++)); do
        distance=$((head > i ? head - i : i - head))
        if (( i == head )); then
            out+="█"
        elif (( distance == 1 )); then
            out+="▓"
        elif (( distance < 4 )); then
            out+="▒"
        else
            out+="░"
        fi
    done
    printf '%s' "$out"
}

render_panel() {
    local top="$1" left="$2" width="$3" app="$4" until_display="$5" quote="$6" scan_row="$7" meter_head="$8"
    local inner=$((width - 2))
    local border separator meter_width meter
    local header_line app_line status_line until_line vector_line quote_line matrix_line
    local lines colors row padded idx bg

    border="$(repeat_char "═" "$inner")"
    separator="$(repeat_char "─" "$((inner - 4))")"
    meter_width=$((inner - 22))
    (( meter_width < 12 )) && meter_width=12
    if (( meter_head >= meter_width )); then
        meter_head=$((meter_width - 1))
    fi
    (( meter_head < 0 )) && meter_head=0
    meter="$(build_meter "$meter_width" "$meter_head")"

    header_line="  OTG / FOCUS PERIMETER :: LOCK SEQUENCE 7A"
    app_line="  APP ............ $(clip_text "$app" "$((inner - 18))")"
    status_line="  STATUS ......... EXECUTION BLOCKED"
    until_line="  UNTIL .......... $(clip_text "$until_display" "$((inner - 18))")"
    vector_line="  VECTOR ......... FOCUS PERIMETER ENGAGED"
    quote_line="  \"$(clip_text "$quote" "$((inner - 6))")\""
    matrix_line="  LOCKOUT MATRIX . $meter"

    lines=(
        "$header_line"
        "  $separator"
        "$app_line"
        "$status_line"
        "$until_line"
        "$vector_line"
        ""
        "$quote_line"
        ""
        "$matrix_line"
    )
    colors=("$CY2" "$SL" "$CY2" "$PK" "$AM" "$TE" "$DM" "$DG" "$DM" "$CY2")

    cursor_to "$top" "$left"
    printf "%b╔%s╗%b" "$PK" "$border" "$N"

    for ((idx = 0; idx < ${#lines[@]}; idx++)); do
        row=$((top + idx + 1))
        padded="$(pad_text "${lines[$idx]}" "$inner")"
        bg=""
        if (( scan_row == idx + 1 )); then
            bg="$BGS"
        fi

        cursor_to "$row" "$left"
        printf "%b║%b%b%s%b%b║%b" "$PK" "$bg" "${colors[$idx]}" "$padded" "$N" "$PK" "$N"
    done

    cursor_to "$((top + ${#lines[@]} + 1))" "$left"
    printf "%b╚%s╝%b" "$PK" "$border" "$N"
}

show_blocked_basic() {
    local app="$1" until_display="$2" quote="$3"
    local bw=48 lp=5
    local border title denied qtext
    local title_rpad denied_rpad app_vis app_rpad status_vis status_rpad until_vis until_rpad q_rpad

    border="$(repeat_char "═" "$bw")"
    title="O F F   T H E   G R I D"
    denied=">>> ACCESS DENIED <<<"
    qtext="\"${quote}\""

    echo ""
    printf "  ${R}╔%s╗${N}\n" "$border"
    printf "  ${R}║${N}%${bw}s${R}║${N}\n" ""

    title_rpad=$((bw - lp - ${#title}))
    printf "  ${R}║${N}%${lp}s${WH}" ""
    typewriter "$title" 0.03
    printf "${N}%${title_rpad}s${R}║${N}\n" ""

    printf "  ${R}║${N}%${bw}s${R}║${N}\n" ""
    printf "  ${R}╠%s╣${N}\n" "$border"
    printf "  ${R}║${N}%${bw}s${R}║${N}\n" ""

    denied_rpad=$((bw - lp - ${#denied}))
    printf "  ${R}║${N}%${lp}s${BR}" ""
    typewriter "$denied" 0.02
    printf "${N}%${denied_rpad}s${R}║${N}\n" ""

    printf "  ${R}║${N}%${bw}s${R}║${N}\n" ""

    app_vis="App:     ${app}"
    app_rpad=$((bw - lp - ${#app_vis}))
    printf "  ${R}║${N}%${lp}s${C}App:${N}     ${WH}%s${N}%${app_rpad}s${R}║${N}\n" "" "$app" ""

    status_vis="Status:  BLOCKED"
    status_rpad=$((bw - lp - ${#status_vis}))
    printf "  ${R}║${N}%${lp}s${C}Status:${N}  ${BR}BLOCKED${N}%${status_rpad}s${R}║${N}\n" "" ""

    until_vis="Until:   ${until_display}"
    until_rpad=$((bw - lp - ${#until_vis}))
    printf "  ${R}║${N}%${lp}s${C}Until:${N}   ${Y}%s${N}%${until_rpad}s${R}║${N}\n" "" "$until_display" ""

    printf "  ${R}║${N}%${bw}s${R}║${N}\n" ""

    q_rpad=$((bw - lp - ${#qtext}))
    printf "  ${R}║${N}%${lp}s${DG}" ""
    typewriter "$qtext" 0.02
    printf "${N}%${q_rpad}s${R}║${N}\n" ""

    printf "  ${R}║${N}%${bw}s${R}║${N}\n" ""
    printf "  ${R}╚%s╝${N}\n" "$border"
    echo ""
}

show_blocked() {
    local app="$1" until_time="${2:-}"
    local until_display quote cols lines
    local boot_row boot_col progress_row bar_w bar_left
    local header subheader header_col subheader_col
    local boot_lines line_idx step fill head empty percent
    local panel_w panel_left panel_top scan meter_width
    local prompt_row progress_fill_color

    if [[ -n "$until_time" ]]; then
        until_display="$until_time"
    else
        until_display="otg off"
    fi
    quote="$(pick_focus_quote)"

    if ! can_render_fx; then
        show_blocked_basic "$app" "$until_display" "$quote"
        return
    fi

    cols="$(term_cols)"
    lines="$(term_lines)"
    if (( cols < 72 || lines < 22 )); then
        show_blocked_basic "$app" "$until_display" "$quote"
        return
    fi

    trap 'show_cursor; printf "\033[0m"' EXIT INT TERM
    hide_cursor

    play_blocked_sound boot
    render_backdrop "$cols" "$lines"

    header="EXECUTION INTERCEPT"
    subheader="app vector rerouted to the focus perimeter"
    header_col=$(((cols - ${#header}) / 2 + 1))
    subheader_col=$(((cols - ${#subheader}) / 2 + 1))
    boot_row=$((lines / 2 - 4))
    boot_col=$((cols / 2 - 19))
    (( boot_row < 6 )) && boot_row=6
    (( boot_col < 6 )) && boot_col=6

    cursor_to "$((boot_row - 2))" "$header_col"
    printf "%b%s%b" "$WH" "$header" "$N"
    cursor_to "$((boot_row - 1))" "$subheader_col"
    printf "%b%s%b" "$SL" "$subheader" "$N"

    boot_lines=(
        "command vector ...... ${app}"
        "policy signature ... focus-lock / matched"
        "response envelope .. quarantine / armed"
    )

    for ((line_idx = 0; line_idx < ${#boot_lines[@]}; line_idx++)); do
        cursor_to "$((boot_row + line_idx))" "$boot_col"
        printf "%b[%02d]%b %b%s%b" "$IG" "$((line_idx + 1))" "$N" "$CY2" "${boot_lines[$line_idx]}" "$N"
        sleep 0.07
    done

    progress_row=$((boot_row + 4))
    bar_w=28
    if (( cols >= 104 )); then
        bar_w=34
    fi
    bar_left=$(((cols - (bar_w + 22)) / 2 + 1))
    (( bar_left < 6 )) && bar_left=6
    progress_fill_color="$TE"

    for ((step = 0; step <= bar_w; step++)); do
        fill="$(repeat_char "█" "$step")"
        if (( step < bar_w )); then
            head="▓"
            empty="$(repeat_char "░" "$((bar_w - step - 1))")"
        else
            head=""
            empty=""
        fi

        percent=$((step * 100 / bar_w))
        cursor_to "$progress_row" "$bar_left"
        printf "%bLOCKOUT MATRIX%b %b[%b%s%b%s%b%s%b] %b%3d%%%b" \
            "$IG" "$N" \
            "$CY2" \
            "$progress_fill_color" "$fill" \
            "$WH" "$head" \
            "$DM" "$empty" \
            "$CY2" \
            "$WH" "$percent" "$N"
        sleep 0.018
    done

    sleep 0.06
    play_blocked_sound deny
    render_backdrop "$cols" "$lines"

    header="APP EXECUTION BLOCKED"
    subheader="synaptic firewall is holding the line"
    header_col=$(((cols - ${#header}) / 2 + 1))
    subheader_col=$(((cols - ${#subheader}) / 2 + 1))
    panel_w=$((cols - 12))
    (( panel_w > 72 )) && panel_w=72
    (( panel_w < 58 )) && panel_w=58
    panel_left=$(((cols - panel_w) / 2 + 1))
    panel_top=$((lines / 2 - 5))
    (( panel_top < 6 )) && panel_top=6

    cursor_to "$((panel_top - 3))" "$header_col"
    printf "%b%s%b" "$WH" "$header" "$N"
    cursor_to "$((panel_top - 2))" "$subheader_col"
    printf "%b%s%b" "$SL" "$subheader" "$N"

    meter_width=$((panel_w - 24))
    (( meter_width < 12 )) && meter_width=12
    for ((scan = 1; scan <= 10; scan++)); do
        render_panel "$panel_top" "$panel_left" "$panel_w" "$app" "$until_display" "$quote" "$scan" "$((scan - 1))"
        sleep 0.045
    done
    render_panel "$panel_top" "$panel_left" "$panel_w" "$app" "$until_display" "$quote" -1 "$((meter_width / 2))"

    prompt_row=$((panel_top + 13))
    if (( prompt_row > lines )); then
        prompt_row="$lines"
    fi
    cursor_to "$prompt_row" 1
    printf '\n'

    show_cursor
    printf '%b' "$N"
    trap - EXIT INT TERM
}

# ─── Commands ────────────────────────────────────

cmd_add() {
    ensure_init
    local app="" from="" to="" days="all"

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --from|-f) from="$2"; shift 2 ;;
            --to|-t)   to="$2"; shift 2 ;;
            --days|-d) days="$2"; shift 2 ;;
            -*)        printf "  ${R}Unknown option: %s${N}\n" "$1"; return 1 ;;
            *)         app="$1"; shift ;;
        esac
    done

    if [[ -z "$app" ]]; then
        printf "  ${R}Usage: otg add <app> [--from HH:MM --to HH:MM] [--days ...]${N}\n"
        return 1
    fi

    validate_app_name "$app" || return 1

    if [[ -n "$from" && -n "$to" ]]; then
        validate_time "$from" || return 1
        validate_time "$to" || return 1
        printf '%s\n' "${from}-${to} ${days}" > "$OTG_APPS_DIR/$app"
        printf "  ${G}+${N} Added ${WH}%s${N} ${DM}(blocked %s-%s, %s)${N}\n" "$app" "$from" "$to" "$days"
    elif [[ -n "$from" || -n "$to" ]]; then
        printf "  ${R}Error: Both --from and --to are required for scheduling${N}\n"
        return 1
    else
        echo "always" > "$OTG_APPS_DIR/$app"
        printf "  ${G}+${N} Added ${WH}%s${N} ${DM}(always blocked when active)${N}\n" "$app"
    fi

    if [[ "$(get_state)" != "on" ]]; then
        printf "  ${DM}Tip: Run 'otg on' to activate blocking${N}\n"
    fi
}

cmd_remove() {
    ensure_init
    local app="${1:-}"

    if [[ -z "$app" ]]; then
        printf "  ${R}Usage: otg remove <app>${N}\n"
        return 1
    fi

    if [[ -f "$OTG_APPS_DIR/$app" ]]; then
        if is_app_blocked "$app"; then
            printf "  ${R}Cannot remove ${WH}%s${N}${R} while the block is active${N}\n" "$app"
            printf "  ${DM}Wait until the schedule ends, or reschedule it so it is not active, then remove it${N}\n"
            return 1
        fi
        rm "$OTG_APPS_DIR/$app"
        printf "  ${R}-${N} Removed ${WH}%s${N} from blocklist\n" "$app"
    else
        printf "  ${Y}%s${N} is not in the blocklist\n" "$app"
    fi
}

cmd_list() {
    ensure_init
    local state
    state=$(get_state)

    echo ""
    if [[ "$state" == "on" ]]; then
        printf "  ${B}Off The Grid${N}  ${G}● ACTIVE${N}\n"
    else
        printf "  ${B}Off The Grid${N}  ${R}○ INACTIVE${N}\n"
    fi
    printf "  ${DM}────────────────────────────────────${N}\n"

    local found=false
    for f in "$OTG_APPS_DIR"/*; do
        [[ -f "$f" ]] || continue
        found=true
        local name schedule
        name="$(basename "$f")"
        schedule="$(cat "$f")"
        if [[ "$schedule" == "always" ]]; then
            printf "  ${WH}%-20s${N}  ${DM}always${N}\n" "$name"
        else
            printf "  ${WH}%-20s${N}  ${DM}%s${N}\n" "$name" "$schedule"
        fi
    done

    if [[ "$found" == false ]]; then
        printf "  ${DM}No apps blocked. Use 'otg add <app>' to get started.${N}\n"
    fi
    echo ""
}

cmd_on() {
    ensure_init
    echo "on" > "$OTG_STATE_FILE"
    local count
    count=$(find "$OTG_APPS_DIR" -maxdepth 1 -type f 2>/dev/null | wc -l | tr -d ' ')
    echo ""
    printf "  ${G}●${N} Off The Grid is now ${G}${B}ACTIVE${N}\n"
    printf "  ${DM}%s app(s) blocked${N}\n" "$count"
    echo ""
}

cmd_off() {
    ensure_init
    local active_apps active_summary="" app

    active_apps="$(active_blocked_apps)"
    if [[ -n "$active_apps" ]]; then
        while IFS= read -r app; do
            [[ -n "$app" ]] || continue
            [[ -n "$active_summary" ]] && active_summary+=", "
            active_summary+="$app"
        done <<< "$active_apps"

        echo ""
        printf "  ${R}Cannot turn Off The Grid off while a block is active${N}\n"
        printf "  ${DM}Active now: %s${N}\n" "$active_summary"
        printf "  ${DM}Wait until the schedule ends, or reschedule the app so it is not active.${N}\n"
        echo ""
        return 1
    fi

    echo "off" > "$OTG_STATE_FILE"
    echo ""
    printf "  ${Y}○${N} Off The Grid is now ${Y}${B}INACTIVE${N}\n"
    printf "  ${DM}All apps accessible${N}\n"
    echo ""
}

cmd_status() {
    ensure_init
    local state count active_apps name schedule
    state=$(get_state)
    count=$(find "$OTG_APPS_DIR" -maxdepth 1 -type f 2>/dev/null | wc -l | tr -d ' ')

    echo ""
    if [[ "$state" == "on" ]]; then
        printf "  ${G}●${N} Off The Grid is ${G}${B}ACTIVE${N}\n"
    else
        printf "  ${R}○${N} Off The Grid is ${R}${B}INACTIVE${N}\n"
    fi
    printf "  ${DM}%s app(s) in blocklist${N}\n" "$count"

    if [[ "$state" == "on" ]]; then
        active_apps="$(active_blocked_apps)"
        echo ""
        if [[ -n "$active_apps" ]]; then
            printf "  ${DM}Blocked apps:${N}\n"
            while IFS= read -r name; do
                [[ -n "$name" ]] || continue
                schedule="$(cat "$OTG_APPS_DIR/$name")"
                if [[ "$schedule" == "always" ]]; then
                    printf "    ${R}■${N} ${WH}%s${N}\n" "$name"
                else
                    printf "    ${Y}■${N} ${WH}%s${N}  ${DM}%s${N}\n" "$name" "$schedule"
                fi
            done <<< "$active_apps"
        else
            printf "  ${DM}No apps are currently blocked right now${N}\n"
        fi
    fi
    echo ""
}

cmd_schedule() {
    ensure_init
    local app="${1:-}"
    shift 2>/dev/null || true

    if [[ -z "$app" ]]; then
        printf "  ${R}Usage: otg schedule <app> --from HH:MM --to HH:MM [--days ...]${N}\n"
        printf "  ${R}       otg schedule <app> --clear${N}\n"
        return 1
    fi

    if [[ ! -f "$OTG_APPS_DIR/$app" ]]; then
        printf "  ${R}%s is not in the blocklist. Add it first: otg add %s${N}\n" "$app" "$app"
        return 1
    fi

    local from="" to="" days="all" clear=false

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --from|-f) from="$2"; shift 2 ;;
            --to|-t)   to="$2"; shift 2 ;;
            --days|-d) days="$2"; shift 2 ;;
            --clear)   clear=true; shift ;;
            *)         shift ;;
        esac
    done

    if [[ "$clear" == true ]]; then
        echo "always" > "$OTG_APPS_DIR/$app"
        printf "  Schedule cleared for ${WH}%s${N} ${DM}(always blocked when active)${N}\n" "$app"
        return 0
    fi

    if [[ -n "$from" && -n "$to" ]]; then
        validate_time "$from" || return 1
        validate_time "$to" || return 1
        printf '%s\n' "${from}-${to} ${days}" > "$OTG_APPS_DIR/$app"
        printf "  Schedule updated: ${WH}%s${N} ${DM}%s-%s (%s)${N}\n" "$app" "$from" "$to" "$days"
    else
        printf "  ${R}Error: Both --from and --to are required${N}\n"
        return 1
    fi
}

cmd_install() {
    ensure_init
    local hook_line="source \"${SCRIPT_DIR}/hooks.zsh\""
    local zshrc="$HOME/.zshrc"

    [[ -f "$zshrc" ]] || touch "$zshrc"

    if grep -qF "offTheGrid" "$zshrc" 2>/dev/null && grep -qF "hooks.zsh" "$zshrc" 2>/dev/null; then
        printf "  ${Y}Already installed in .zshrc${N}\n"
        return 0
    fi

    {
        echo ""
        echo "# Off The Grid — app blocker"
        echo "$hook_line"
    } >> "$zshrc"

    echo ""
    printf "  ${G}Installed successfully.${N}\n"
    echo ""
    printf "  Restart your terminal or run: ${WH}source ~/.zshrc${N}\n"
    printf "  Then: ${WH}otg add <app>${N} to block an app\n"
    printf "        ${WH}otg on${N} to activate\n"
    echo ""
}

cmd_uninstall() {
    local zshrc="$HOME/.zshrc"
    if [[ -f "$zshrc" ]]; then
        local tmp
        tmp=$(mktemp)
        grep -v '# Off The Grid' "$zshrc" | grep -v 'offTheGrid.*hooks\.zsh' > "$tmp" || true
        mv "$tmp" "$zshrc"
        printf "  ${G}Uninstalled.${N} Restart your terminal.\n"
    else
        printf "  ${Y}Nothing to uninstall.${N}\n"
    fi
}

cmd_help() {
    echo ""
    printf "  ${B}Off The Grid${N} — command-line app blocker\n"
    echo ""
    printf "  ${WH}Usage:${N} otg ${C}<command>${N} [options]\n"
    echo ""
    printf "  ${WH}Commands:${N}\n"
    printf "    ${C}add${N} <app> [--from HH:MM --to HH:MM --days ...]  Block an app\n"
    printf "    ${C}remove${N} <app>                                     Unblock an app\n"
    printf "    ${C}list${N}                                             Show blocked apps\n"
    printf "    ${C}on${N}                                               Activate blocking\n"
    printf "    ${C}off${N}                                              Deactivate when no block is active\n"
    printf "    ${C}status${N}                                           Current state\n"
    printf "    ${C}schedule${N} <app> --from HH:MM --to HH:MM          Set a schedule\n"
    printf "    ${C}schedule${N} <app> --clear                           Clear schedule\n"
    printf "    ${C}install${N}                                          Set up shell hooks\n"
    printf "    ${C}uninstall${N}                                        Remove shell hooks\n"
    printf "    ${C}help${N}                                             Show this help\n"
    echo ""
    printf "  ${WH}Day options:${N}\n"
    printf "    ${DM}weekdays, weekends, all, or comma-separated: mon,tue,wed,thu,fri${N}\n"
    echo ""
    printf "  ${WH}Examples:${N}\n"
    printf "    ${DM}otg add claude                                 # block always${N}\n"
    printf "    ${DM}otg add claude --from 09:00 --to 17:00         # block 9am-5pm${N}\n"
    printf "    ${DM}otg add chatgpt -f 09:00 -t 17:00 -d weekdays # weekdays only${N}\n"
    printf "    ${DM}otg on                                         # activate${N}\n"
    printf "    ${DM}otg off                                        # deactivate${N}\n"
    echo ""
}

# ─── Internal (called by shell hooks) ────────────

cmd__blocked() {
    show_blocked "${1:-unknown}" "${2:-}"
}

# ─── Main ────────────────────────────────────────

main() {
    local cmd="${1:-help}"
    shift 2>/dev/null || true

    case "$cmd" in
        add)            cmd_add "$@" ;;
        remove|rm)      cmd_remove "$@" ;;
        list|ls)        cmd_list ;;
        on)             cmd_on ;;
        off)            cmd_off ;;
        status|st)      cmd_status ;;
        schedule|sched) cmd_schedule "$@" ;;
        install)        cmd_install ;;
        uninstall)      cmd_uninstall ;;
        help|--help|-h) cmd_help ;;
        _blocked)       cmd__blocked "$@" ;;
        *)
            printf "  ${R}Unknown command: %s${N}\n" "$cmd"
            printf "  Run ${WH}otg help${N} for usage.\n"
            return 1
            ;;
    esac
}

main "$@"
