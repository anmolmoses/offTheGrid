#!/usr/bin/env bash
# otg — Off The Grid: command-line app blocker
# Block any CLI app on a schedule or on demand.
set -euo pipefail

OTG_DIR="${OTG_DIR:-$HOME/.offthegrid}"
OTG_APPS_DIR="$OTG_DIR/apps"
OTG_STATE_FILE="$OTG_DIR/state"
OTG_CACHE_DIR="$OTG_DIR/cache"
# Bump this when embedded audio changes so stale cached WAVs refresh automatically.
OTG_AUDIO_CACHE_TAG="stereo_v2"
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# ─── Colors ──────────────────────────────────────

R=$'\e[0;31m'
BR=$'\e[1;31m'
G=$'\e[0;32m'
Y=$'\e[1;33m'
C=$'\e[0;36m'
WH=$'\e[1;37m'
DM=$'\e[2m'
DG=$'\e[2;32m'
B=$'\e[1m'
N=$'\e[0m'
CY2=$'\e[38;2;102;234;255m'
TE=$'\e[38;2;107;255;223m'
PK=$'\e[38;2;255;116;156m'
AM=$'\e[38;2;255;194;104m'
SL=$'\e[38;2;126;147;166m'
IG=$'\e[38;2;153;170;185m'
BGS=$'\e[48;2;10;34;40m'

OTG_BUNDLED_BOOT_WAV_B64=''
OTG_BUNDLED_DENY_WAV_B64=''

# ─── Utilities ───────────────────────────────────

ensure_init() {
    mkdir -p "$OTG_APPS_DIR" "$OTG_CACHE_DIR"
    [[ -f "$OTG_STATE_FILE" ]] || echo "off" > "$OTG_STATE_FILE"
}

get_state() {
    if [[ -f "$OTG_STATE_FILE" ]]; then
        cat "$OTG_STATE_FILE"
    else
        echo "off"
    fi
}

validate_app_name() {
    if [[ ! "$1" =~ ^[a-zA-Z0-9_.-]+$ ]]; then
        printf "  ${R}Error: App name must contain only letters, numbers, hyphens, dots, underscores${N}\n"
        return 1
    fi
}

validate_time() {
    if [[ ! "$1" =~ ^([0-9]|[01][0-9]|2[0-3]):[0-5][0-9]$ ]]; then
        printf "  ${R}Error: Invalid time. Use H:MM or HH:MM in 24h format (e.g. 9:00, 09:00, 17:30)${N}\n"
        return 1
    fi
}

time_to_min() {
    local t="$1"
    echo $(( 10#${t%%:*} * 60 + 10#${t##*:} ))
}

day_match() {
    local days="$1"
    local today
    today=$(date +%a | tr '[:upper:]' '[:lower:]')

    case "$days" in
        all) return 0 ;;
        weekdays)
            case "$today" in
                mon|tue|wed|thu|fri) return 0 ;;
                *) return 1 ;;
            esac
            ;;
        weekends)
            case "$today" in
                sat|sun) return 0 ;;
                *) return 1 ;;
            esac
            ;;
        *)
            [[ ",$days," == *",$today,"* ]] && return 0
            return 1
            ;;
    esac
}

is_app_blocked() {
    local app="$1"
    local app_file="$OTG_APPS_DIR/$app"

    [[ "$(get_state)" == "on" ]] || return 1
    [[ -f "$app_file" ]] || return 1

    local sched
    sched="$(< "$app_file")"

    [[ "$sched" == "always" ]] && return 0

    local line
    while IFS= read -r line; do
        [[ -z "$line" || "$line" == \#* ]] && continue

        local range="${line%% *}"
        local days="${line##* }"
        [[ "$days" == "$range" ]] && days="all"

        day_match "$days" || continue

        local s_time="${range%%-*}"
        local e_time="${range##*-}"
        local now
        now=$(time_to_min "$(date +%H:%M)")
        local s e
        s=$(time_to_min "$s_time")
        e=$(time_to_min "$e_time")

        if (( s <= e )); then
            if (( now >= s && now < e )); then
                return 0
            fi
        else
            if (( now >= s || now < e )); then
                return 0
            fi
        fi
    done <<< "$sched"

    return 1
}

active_blocked_apps() {
    ensure_init
    local f name

    [[ "$(get_state)" == "on" ]] || return 0

    for f in "$OTG_APPS_DIR"/*; do
        [[ -f "$f" ]] || continue
        name="$(basename "$f")"

        if is_app_blocked "$name"; then
            printf '%s\n' "$name"
        fi
    done
}

typewriter() {
    local text="$1" delay="${2:-0.02}" i
    for ((i = 0; i < ${#text}; i++)); do
        printf '%s' "${text:$i:1}"
        sleep "$delay"
    done
}

repeat_char() {
    local ch="$1" count="$2" out="" i
    for ((i = 0; i < count; i++)); do
        out+="$ch"
    done
    printf '%s' "$out"
}

cursor_to() {
    printf '\033[%s;%sH' "$1" "$2"
}

clear_screen() {
    printf '\033[2J\033[H'
}

hide_cursor() {
    tput civis 2>/dev/null || printf '\033[?25l'
}

show_cursor() {
    tput cnorm 2>/dev/null || printf '\033[?25h'
}

term_cols() {
    tput cols 2>/dev/null || echo "${COLUMNS:-80}"
}

term_lines() {
    tput lines 2>/dev/null || echo "${LINES:-24}"
}

pad_text() {
    local text="$1" width="$2"
    if (( width <= 0 )); then
        printf ''
        return
    fi

    if (( ${#text} > width )); then
        printf '%s' "${text:0:width}"
    else
        printf '%-*s' "$width" "$text"
    fi
}

clip_text() {
    local text="$1" width="$2" keep

    if (( width <= 0 )); then
        printf ''
        return
    fi

    if (( ${#text} <= width )); then
        printf '%s' "$text"
        return
    fi

    if (( width <= 3 )); then
        printf '%s' "${text:0:width}"
        return
    fi

    keep=$((width - 3))
    printf '%s...' "${text:0:keep}"
}

