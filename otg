#!/usr/bin/env bash
# otg — Off The Grid: command-line app blocker
# Block any CLI app on a schedule or on demand.
set -euo pipefail

OTG_DIR="${OTG_DIR:-$HOME/.offthegrid}"
OTG_APPS_DIR="$OTG_DIR/apps"
OTG_STATE_FILE="$OTG_DIR/state"
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# ─── Colors ──────────────────────────────────────

R=$'\e[0;31m'
BR=$'\e[1;31m'
G=$'\e[0;32m'
Y=$'\e[1;33m'
C=$'\e[0;36m'
WH=$'\e[1;37m'
DM=$'\e[2m'
DG=$'\e[2;32m'
B=$'\e[1m'
N=$'\e[0m'

# ─── Utilities ───────────────────────────────────

ensure_init() {
    mkdir -p "$OTG_APPS_DIR"
    [[ -f "$OTG_STATE_FILE" ]] || echo "off" > "$OTG_STATE_FILE"
}

get_state() {
    if [[ -f "$OTG_STATE_FILE" ]]; then
        cat "$OTG_STATE_FILE"
    else
        echo "off"
    fi
}

validate_app_name() {
    if [[ ! "$1" =~ ^[a-zA-Z0-9_.-]+$ ]]; then
        printf "  ${R}Error: App name must contain only letters, numbers, hyphens, dots, underscores${N}\n"
        return 1
    fi
}

validate_time() {
    if [[ ! "$1" =~ ^([0-9]|[01][0-9]|2[0-3]):[0-5][0-9]$ ]]; then
        printf "  ${R}Error: Invalid time. Use H:MM or HH:MM in 24h format (e.g. 9:00, 09:00, 17:30)${N}\n"
        return 1
    fi
}

time_to_min() {
    local t="$1"
    echo $(( 10#${t%%:*} * 60 + 10#${t##*:} ))
}

day_match() {
    local days="$1"
    local today
    today=$(date +%a | tr '[:upper:]' '[:lower:]')

    case "$days" in
        all) return 0 ;;
        weekdays)
            case "$today" in
                mon|tue|wed|thu|fri) return 0 ;;
                *) return 1 ;;
            esac
            ;;
        weekends)
            case "$today" in
                sat|sun) return 0 ;;
                *) return 1 ;;
            esac
            ;;
        *)
            [[ ",$days," == *",$today,"* ]] && return 0
            return 1
            ;;
    esac
}

is_app_blocked() {
    local app="$1"
    local app_file="$OTG_APPS_DIR/$app"

    [[ "$(get_state)" == "on" ]] || return 1
    [[ -f "$app_file" ]] || return 1

    local sched
    sched="$(< "$app_file")"

    [[ "$sched" == "always" ]] && return 0

    local line
    while IFS= read -r line; do
        [[ -z "$line" || "$line" == \#* ]] && continue

        local range="${line%% *}"
        local days="${line##* }"
        [[ "$days" == "$range" ]] && days="all"

        day_match "$days" || continue

        local s_time="${range%%-*}"
        local e_time="${range##*-}"
        local now
        now=$(time_to_min "$(date +%H:%M)")
        local s e
        s=$(time_to_min "$s_time")
        e=$(time_to_min "$e_time")

        if (( s <= e )); then
            if (( now >= s && now < e )); then
                return 0
            fi
        else
            if (( now >= s || now < e )); then
                return 0
            fi
        fi
    done <<< "$sched"

    return 1
}

typewriter() {
    local text="$1" delay="${2:-0.02}" i
    for ((i = 0; i < ${#text}; i++)); do
        printf '%s' "${text:$i:1}"
        sleep "$delay"
    done
}

# ─── Blocked Screen Animation ────────────────────

show_blocked() {
    local app="$1"
    local until_time="${2:-}"

    local bw=48  # box interior width
    local lp=5   # left content padding

    # Build border string
    local border="" i
    for ((i = 0; i < bw; i++)); do border+="═"; done

    # Random motivational quote (50 quotes, shuffled each time)
    local quotes=(
        "Deep work is rare and valuable."
        "Focus is your superpower."
        "You don't need AI for this moment."
        "The best thinking happens offline."
        "Distraction is the thief of ambition."
        "Trust yourself. You know enough."
        "The zone is worth protecting."
        "Presence over productivity."
        "Do the work. Trust the process."
        "Stay in the arena. Do the work."
        "Do the work. Skip the noise."
        "Focus is a muscle. Train it."
        "Deep work breeds rare results."
        "Be where your feet are."
        "Discipline is freedom."
        "The best app is your mind."
        "Guard your attention fiercely."
        "What you feed grows."
        "Start before you're ready."
        "Log off. Lock in."
        "Less input, more output."
        "Silence is productive."
        "Own your hours."
        "Hard things build strong people."
        "Shallow days make shallow lives."
        "Protect your peak hours."
        "The cave you fear holds your gold."
        "Boredom is where genius hides."
        "Go dark. Go deep."
        "Do less, but do it fully."
        "Be unreachable sometimes."
        "Flow state over feed state."
        "You already know what to do."
        "Depth over breadth. Always."
        "Build in silence."
        "Comfort kills ambition."
        "Attention is your greatest asset."
        "Real work feels like resistance."
        "Presence is power."
        "Show up before motivation does."
        "Solitude sharpens the mind."
        "Mastery demands monotony."
        "Unplug to upgrade."
        "The obstacle is the way."
        "Stop consuming. Start producing."
        "Small focus, big results."
        "Stay the course."
        "You are not your notifications."
        "Stillness is the key."
        "Don't react. Create."
    )
    local quote="${quotes[$((RANDOM % ${#quotes[@]}))]}"

    # ── Draw the box ──

    echo ""

    # Top border
    printf "  ${R}╔%s╗${N}\n" "$border"

    # Empty line
    printf "  ${R}║${N}%${bw}s${R}║${N}\n" ""

    # Title — typewriter effect
    local title="O F F   T H E   G R I D"
    local title_rpad=$((bw - lp - ${#title}))
    printf "  ${R}║${N}%${lp}s${WH}" ""
    typewriter "$title" 0.03
    printf "${N}%${title_rpad}s${R}║${N}\n" ""

    # Empty line
    printf "  ${R}║${N}%${bw}s${R}║${N}\n" ""

    # Separator
    printf "  ${R}╠%s╣${N}\n" "$border"

    # Empty line
    printf "  ${R}║${N}%${bw}s${R}║${N}\n" ""

    # Access denied — typewriter effect
    local denied=">>> ACCESS DENIED <<<"
    local denied_rpad=$((bw - lp - ${#denied}))
    printf "  ${R}║${N}%${lp}s${BR}" ""
    typewriter "$denied" 0.02
    printf "${N}%${denied_rpad}s${R}║${N}\n" ""

    # Empty line
    printf "  ${R}║${N}%${bw}s${R}║${N}\n" ""

    # App name
    local app_vis="App:     ${app}"
    local app_rpad=$((bw - lp - ${#app_vis}))
    printf "  ${R}║${N}%${lp}s${C}App:${N}     ${WH}%s${N}%${app_rpad}s${R}║${N}\n" "" "$app" ""

    # Status
    local status_vis="Status:  BLOCKED"
    local status_rpad=$((bw - lp - ${#status_vis}))
    printf "  ${R}║${N}%${lp}s${C}Status:${N}  ${BR}BLOCKED${N}%${status_rpad}s${R}║${N}\n" "" ""

    # Until
    local until_display
    if [[ -n "$until_time" ]]; then
        until_display="$until_time"
    else
        until_display="otg off"
    fi
    local until_vis="Until:   ${until_display}"
    local until_rpad=$((bw - lp - ${#until_vis}))
    printf "  ${R}║${N}%${lp}s${C}Until:${N}   ${Y}%s${N}%${until_rpad}s${R}║${N}\n" "" "$until_display" ""

    # Empty line
    printf "  ${R}║${N}%${bw}s${R}║${N}\n" ""

    # Quote — typewriter effect
    local qtext="\"${quote}\""
    local q_rpad=$((bw - lp - ${#qtext}))
    printf "  ${R}║${N}%${lp}s${DG}" ""
    typewriter "$qtext" 0.02
    printf "${N}%${q_rpad}s${R}║${N}\n" ""

    # Empty line
    printf "  ${R}║${N}%${bw}s${R}║${N}\n" ""

    # Bottom border
    printf "  ${R}╚%s╝${N}\n" "$border"

    echo ""
}

# ─── Commands ────────────────────────────────────

cmd_add() {
    ensure_init
    local app="" from="" to="" days="all"

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --from|-f) from="$2"; shift 2 ;;
            --to|-t)   to="$2"; shift 2 ;;
            --days|-d) days="$2"; shift 2 ;;
            -*)        printf "  ${R}Unknown option: %s${N}\n" "$1"; return 1 ;;
            *)         app="$1"; shift ;;
        esac
    done

    if [[ -z "$app" ]]; then
        printf "  ${R}Usage: otg add <app> [--from HH:MM --to HH:MM] [--days ...]${N}\n"
        return 1
    fi

    validate_app_name "$app" || return 1

    if [[ -n "$from" && -n "$to" ]]; then
        validate_time "$from" || return 1
        validate_time "$to" || return 1
        printf '%s\n' "${from}-${to} ${days}" > "$OTG_APPS_DIR/$app"
        printf "  ${G}+${N} Added ${WH}%s${N} ${DM}(blocked %s-%s, %s)${N}\n" "$app" "$from" "$to" "$days"
    elif [[ -n "$from" || -n "$to" ]]; then
        printf "  ${R}Error: Both --from and --to are required for scheduling${N}\n"
        return 1
    else
        echo "always" > "$OTG_APPS_DIR/$app"
        printf "  ${G}+${N} Added ${WH}%s${N} ${DM}(always blocked when active)${N}\n" "$app"
    fi

    if [[ "$(get_state)" != "on" ]]; then
        printf "  ${DM}Tip: Run 'otg on' to activate blocking${N}\n"
    fi
}

cmd_remove() {
    ensure_init
    local app="${1:-}"

    if [[ -z "$app" ]]; then
        printf "  ${R}Usage: otg remove <app>${N}\n"
        return 1
    fi

    if [[ -f "$OTG_APPS_DIR/$app" ]]; then
        if is_app_blocked "$app"; then
            printf "  ${R}Cannot remove ${WH}%s${N}${R} while the block is active${N}\n" "$app"
            printf "  ${DM}Deactivate first with 'otg off' or wait until the schedule ends${N}\n"
            return 1
        fi
        rm "$OTG_APPS_DIR/$app"
        printf "  ${R}-${N} Removed ${WH}%s${N} from blocklist\n" "$app"
    else
        printf "  ${Y}%s${N} is not in the blocklist\n" "$app"
    fi
}

cmd_list() {
    ensure_init
    local state
    state=$(get_state)

    echo ""
    if [[ "$state" == "on" ]]; then
        printf "  ${B}Off The Grid${N}  ${G}● ACTIVE${N}\n"
    else
        printf "  ${B}Off The Grid${N}  ${R}○ INACTIVE${N}\n"
    fi
    printf "  ${DM}────────────────────────────────────${N}\n"

    local found=false
    for f in "$OTG_APPS_DIR"/*; do
        [[ -f "$f" ]] || continue
        found=true
        local name schedule
        name="$(basename "$f")"
        schedule="$(cat "$f")"
        if [[ "$schedule" == "always" ]]; then
            printf "  ${WH}%-20s${N}  ${DM}always${N}\n" "$name"
        else
            printf "  ${WH}%-20s${N}  ${DM}%s${N}\n" "$name" "$schedule"
        fi
    done

    if [[ "$found" == false ]]; then
        printf "  ${DM}No apps blocked. Use 'otg add <app>' to get started.${N}\n"
    fi
    echo ""
}

cmd_on() {
    ensure_init
    echo "on" > "$OTG_STATE_FILE"
    local count
    count=$(find "$OTG_APPS_DIR" -maxdepth 1 -type f 2>/dev/null | wc -l | tr -d ' ')
    echo ""
    printf "  ${G}●${N} Off The Grid is now ${G}${B}ACTIVE${N}\n"
    printf "  ${DM}%s app(s) blocked${N}\n" "$count"
    echo ""
}

cmd_off() {
    ensure_init
    echo "off" > "$OTG_STATE_FILE"
    echo ""
    printf "  ${Y}○${N} Off The Grid is now ${Y}${B}INACTIVE${N}\n"
    printf "  ${DM}All apps accessible${N}\n"
    echo ""
}

cmd_status() {
    ensure_init
    local state count
    state=$(get_state)
    count=$(find "$OTG_APPS_DIR" -maxdepth 1 -type f 2>/dev/null | wc -l | tr -d ' ')

    echo ""
    if [[ "$state" == "on" ]]; then
        printf "  ${G}●${N} Off The Grid is ${G}${B}ACTIVE${N}\n"
    else
        printf "  ${R}○${N} Off The Grid is ${R}${B}INACTIVE${N}\n"
    fi
    printf "  ${DM}%s app(s) in blocklist${N}\n" "$count"

    if [[ "$state" == "on" ]] && [[ -n "$(ls -A "$OTG_APPS_DIR" 2>/dev/null)" ]]; then
        echo ""
        printf "  ${DM}Blocked apps:${N}\n"
        for f in "$OTG_APPS_DIR"/*; do
            [[ -f "$f" ]] || continue
            local name schedule
            name="$(basename "$f")"
            schedule="$(cat "$f")"
            if [[ "$schedule" == "always" ]]; then
                printf "    ${R}■${N} ${WH}%s${N}\n" "$name"
            else
                printf "    ${Y}■${N} ${WH}%s${N}  ${DM}%s${N}\n" "$name" "$schedule"
            fi
        done
    fi
    echo ""
}

cmd_schedule() {
    ensure_init
    local app="${1:-}"
    shift 2>/dev/null || true

    if [[ -z "$app" ]]; then
        printf "  ${R}Usage: otg schedule <app> --from HH:MM --to HH:MM [--days ...]${N}\n"
        printf "  ${R}       otg schedule <app> --clear${N}\n"
        return 1
    fi

    if [[ ! -f "$OTG_APPS_DIR/$app" ]]; then
        printf "  ${R}%s is not in the blocklist. Add it first: otg add %s${N}\n" "$app" "$app"
        return 1
    fi

    local from="" to="" days="all" clear=false

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --from|-f) from="$2"; shift 2 ;;
            --to|-t)   to="$2"; shift 2 ;;
            --days|-d) days="$2"; shift 2 ;;
            --clear)   clear=true; shift ;;
            *)         shift ;;
        esac
    done

    if [[ "$clear" == true ]]; then
        echo "always" > "$OTG_APPS_DIR/$app"
        printf "  Schedule cleared for ${WH}%s${N} ${DM}(always blocked when active)${N}\n" "$app"
        return 0
    fi

    if [[ -n "$from" && -n "$to" ]]; then
        validate_time "$from" || return 1
        validate_time "$to" || return 1
        printf '%s\n' "${from}-${to} ${days}" > "$OTG_APPS_DIR/$app"
        printf "  Schedule updated: ${WH}%s${N} ${DM}%s-%s (%s)${N}\n" "$app" "$from" "$to" "$days"
    else
        printf "  ${R}Error: Both --from and --to are required${N}\n"
        return 1
    fi
}

cmd_install() {
    ensure_init
    local hook_line="source \"${SCRIPT_DIR}/hooks.zsh\""
    local zshrc="$HOME/.zshrc"

    [[ -f "$zshrc" ]] || touch "$zshrc"

    if grep -qF "offTheGrid" "$zshrc" 2>/dev/null && grep -qF "hooks.zsh" "$zshrc" 2>/dev/null; then
        printf "  ${Y}Already installed in .zshrc${N}\n"
        return 0
    fi

    {
        echo ""
        echo "# Off The Grid — app blocker"
        echo "$hook_line"
    } >> "$zshrc"

    echo ""
    printf "  ${G}Installed successfully.${N}\n"
    echo ""
    printf "  Restart your terminal or run: ${WH}source ~/.zshrc${N}\n"
    printf "  Then: ${WH}otg add <app>${N} to block an app\n"
    printf "        ${WH}otg on${N} to activate\n"
    echo ""
}

cmd_uninstall() {
    local zshrc="$HOME/.zshrc"
    if [[ -f "$zshrc" ]]; then
        local tmp
        tmp=$(mktemp)
        grep -v '# Off The Grid' "$zshrc" | grep -v 'offTheGrid.*hooks\.zsh' > "$tmp" || true
        mv "$tmp" "$zshrc"
        printf "  ${G}Uninstalled.${N} Restart your terminal.\n"
    else
        printf "  ${Y}Nothing to uninstall.${N}\n"
    fi
}

cmd_help() {
    echo ""
    printf "  ${B}Off The Grid${N} — command-line app blocker\n"
    echo ""
    printf "  ${WH}Usage:${N} otg ${C}<command>${N} [options]\n"
    echo ""
    printf "  ${WH}Commands:${N}\n"
    printf "    ${C}add${N} <app> [--from HH:MM --to HH:MM --days ...]  Block an app\n"
    printf "    ${C}remove${N} <app>                                     Unblock an app\n"
    printf "    ${C}list${N}                                             Show blocked apps\n"
    printf "    ${C}on${N}                                               Activate blocking\n"
    printf "    ${C}off${N}                                              Deactivate blocking\n"
    printf "    ${C}status${N}                                           Current state\n"
    printf "    ${C}schedule${N} <app> --from HH:MM --to HH:MM          Set a schedule\n"
    printf "    ${C}schedule${N} <app> --clear                           Clear schedule\n"
    printf "    ${C}install${N}                                          Set up shell hooks\n"
    printf "    ${C}uninstall${N}                                        Remove shell hooks\n"
    printf "    ${C}help${N}                                             Show this help\n"
    echo ""
    printf "  ${WH}Day options:${N}\n"
    printf "    ${DM}weekdays, weekends, all, or comma-separated: mon,tue,wed,thu,fri${N}\n"
    echo ""
    printf "  ${WH}Examples:${N}\n"
    printf "    ${DM}otg add claude                                 # block always${N}\n"
    printf "    ${DM}otg add claude --from 09:00 --to 17:00         # block 9am-5pm${N}\n"
    printf "    ${DM}otg add chatgpt -f 09:00 -t 17:00 -d weekdays # weekdays only${N}\n"
    printf "    ${DM}otg on                                         # activate${N}\n"
    printf "    ${DM}otg off                                        # deactivate${N}\n"
    echo ""
}

# ─── Internal (called by shell hooks) ────────────

cmd__blocked() {
    show_blocked "${1:-unknown}" "${2:-}"
}

# ─── Main ────────────────────────────────────────

main() {
    local cmd="${1:-help}"
    shift 2>/dev/null || true

    case "$cmd" in
        add)            cmd_add "$@" ;;
        remove|rm)      cmd_remove "$@" ;;
        list|ls)        cmd_list ;;
        on)             cmd_on ;;
        off)            cmd_off ;;
        status|st)      cmd_status ;;
        schedule|sched) cmd_schedule "$@" ;;
        install)        cmd_install ;;
        uninstall)      cmd_uninstall ;;
        help|--help|-h) cmd_help ;;
        _blocked)       cmd__blocked "$@" ;;
        *)
            printf "  ${R}Unknown command: %s${N}\n" "$cmd"
            printf "  Run ${WH}otg help${N} for usage.\n"
            return 1
            ;;
    esac
}

main "$@"
